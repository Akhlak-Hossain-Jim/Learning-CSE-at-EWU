<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Curved red header -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/curved_header_height"
        android:background="@drawable/bg_curved_header" />

    <!-- Header: back arrow + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:layout_marginTop="44dp">

        <ImageButton
            android:id="@+id/btnBack"
            style="@style/HeaderBackButton"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_md"
            android:text="@string/title_edit_profile"
            style="@style/TextHeaderTitle" />

    </LinearLayout>

    <!-- Scrollable form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="140dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingTop="@dimen/space_lg"
            android:paddingBottom="@dimen/space_xl">

            <!-- Full Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilFullName"
                style="@style/InputField"
                android:hint="@string/label_full_name">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:inputType="textPersonName"
                    android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPhone"
                style="@style/InputField"
                android:layout_marginTop="@dimen/field_spacing"
                android:hint="@string/label_phone">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:inputType="phone"
                    android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Blood group section (donors only) -->
            <LinearLayout
                android:id="@+id/layoutBloodGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:layout_marginBottom="@dimen/space_sm"
                    android:text="@string/blood_group_label"
                    style="@style/TextLabelLarge" />

                <!-- Row 1: Type -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="4">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTypeA"
                        style="@style/BloodGroupPill"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:text="@string/blood_group_a" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTypeB"
                        style="@style/BloodGroupPill"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:text="@string/blood_group_b" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTypeAB"
                        style="@style/BloodGroupPill"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:text="@string/blood_group_ab" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTypeO"
                        style="@style/BloodGroupPill"
                        android:layout_weight="1"
                        android:text="@string/blood_group_o" />

                </LinearLayout>

                <!-- Row 2: Rh factor -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/space_sm"
                    android:weightSum="4">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRhPos"
                        style="@style/BloodGroupPill"
                        android:layout_weight="2"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:text="@string/rh_positive" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRhNeg"
                        style="@style/BloodGroupPill"
                        android:layout_weight="2"
                        android:text="@string/rh_negative" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvBloodGroupError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:layout_marginStart="@dimen/space_md"
                    android:text="@string/error_blood_group_required"
                    android:textColor="@color/colorCritical"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- City -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCity"
                style="@style/InputField"
                android:layout_marginTop="@dimen/field_spacing"
                android:hint="@string/label_city">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCity"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:inputType="textCapWords"
                    android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- District -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDistrict"
                style="@style/InputField"
                android:layout_marginTop="@dimen/field_spacing"
                android:hint="@string/label_district">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDistrict"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:inputType="textCapWords"
                    android:imeOptions="actionDone" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Availability toggle (donors only) -->
            <LinearLayout
                android:id="@+id/layoutAvailability"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/space_lg"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_availability"
                    style="@style/TextLabelLarge" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAvailability"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/colorPrimary"
                    app:trackTint="@color/colorPrimaryLight" />

            </LinearLayout>

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/PrimaryButton"
                android:layout_marginTop="@dimen/space_xl"
                android:text="@string/btn_save" />

        </LinearLayout>
    </ScrollView>

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/white" />

    </FrameLayout>

</FrameLayout>
