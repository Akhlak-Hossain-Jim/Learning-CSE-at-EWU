<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Curved red header with avatar overlapping ──────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <!-- Background curve -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_curved_header" />

            <!-- Avatar circle centred at the bottom edge of header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_gravity="bottom|center_horizontal">

                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_red"
                    android:textColor="@color/colorPrimary"
                    android:textSize="28sp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="U"
                    android:contentDescription="@string/cd_avatar" />

            </LinearLayout>

        </FrameLayout>

        <!-- ── Name + role badge (pushed below avatar) ───────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="48dp"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                style="@style/TextHeading1"
                android:gravity="center" />

            <!-- Role badge pill -->
            <TextView
                android:id="@+id/tvRoleBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:paddingStart="@dimen/space_lg"
                android:paddingEnd="@dimen/space_lg"
                android:paddingTop="@dimen/space_xs"
                android:paddingBottom="@dimen/space_xs"
                android:text="@string/label_donor_badge"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:background="@drawable/bg_badge_rounded" />

        </LinearLayout>

        <!-- ── Info cards section ────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingTop="@dimen/space_lg">

            <!-- Contact info card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/card_spacing">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact"
                        style="@style/TextLabelLarge"
                        android:layout_marginBottom="@dimen/space_sm" />

                    <!-- Email row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/space_sm">

                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Email"
                            style="@style/TextBodySmall" />

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            style="@style/TextBodyLarge" />

                    </LinearLayout>

                    <!-- Phone row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Phone"
                            style="@style/TextBodySmall" />

                        <TextView
                            android:id="@+id/tvPhone"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            style="@style/TextBodyLarge" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Donor-specific card (blood type + location) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDonorInfo"
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/card_spacing"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Donor Info"
                        style="@style/TextLabelLarge"
                        android:layout_marginBottom="@dimen/space_sm" />

                    <!-- Blood group row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/space_sm">

                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Blood"
                            style="@style/TextBodySmall" />

                        <TextView
                            android:id="@+id/tvBloodGroup"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textColor="@color/colorPrimary"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="16sp" />

                    </LinearLayout>

                    <!-- Location row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/space_sm">

                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            style="@style/TextBodySmall" />

                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            style="@style/TextBodyLarge" />

                    </LinearLayout>

                    <!-- Availability row (donors only) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Status"
                            style="@style/TextBodySmall" />

                        <TextView
                            android:id="@+id/tvAvailability"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_available"
                            android:textColor="@color/colorSuccess"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_medium" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Edit Profile button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditProfile"
                style="@style/PrimaryButton"
                android:layout_marginBottom="@dimen/space_sm"
                android:text="@string/btn_edit_profile" />

            <!-- Donation History button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDonationInfo"
                style="@style/SecondaryButton"
                android:layout_marginBottom="@dimen/space_sm"
                android:text="@string/label_donation_history" />

            <!-- Donate Money button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDonateMoney"
                style="@style/SecondaryButton"
                android:layout_marginBottom="@dimen/space_sm"
                android:text="@string/btn_donate_money" />

            <!-- My Requests button (recipients only) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMyRequests"
                style="@style/SecondaryButton"
                android:layout_marginBottom="@dimen/space_sm"
                android:text="@string/btn_my_requests"
                android:visibility="gone" />

            <!-- Logout button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_sm"
                android:layout_marginBottom="@dimen/space_xl"
                android:text="@string/btn_logout"
                android:textColor="@color/colorPrimary" />

        </LinearLayout>

        <!-- Loading overlay -->
        <FrameLayout
            android:id="@+id/loadingOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80000000"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/white" />

        </FrameLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
