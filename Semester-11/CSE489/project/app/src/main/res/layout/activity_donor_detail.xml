<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Curved red header (taller for donor detail) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_curved_header" />

    <!-- Back button -->
    <ImageButton
        android:id="@+id/btnBack"
        style="@style/HeaderBackButton"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginTop="44dp"
        android:src="@drawable/ic_arrow_back" />

    <!-- Header donor profile summary -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="72dp">

        <!-- Large blood group badge -->
        <TextView
            android:id="@+id/tvBloodGroupLarge"
            android:layout_width="@dimen/blood_badge_lg"
            android:layout_height="@dimen/blood_badge_lg"
            android:gravity="center"
            android:background="@drawable/bg_circle_red"
            android:textColor="@color/colorPrimary"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"
            android:text="—" />

        <!-- Donor name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="Donor Name"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_semibold" />

        <!-- Availability status pill -->
        <TextView
            android:id="@+id/tvAvailabilityStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:paddingTop="@dimen/space_xs"
            android:paddingBottom="@dimen/space_xs"
            android:text="@string/label_available"
            android:textColor="@color/colorSuccess"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_medium"
            android:background="@drawable/bg_tag_normal" />

    </LinearLayout>

    <!-- Detail cards scrollable body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="210dp"
        android:layout_marginBottom="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingTop="@dimen/space_md"
            android:paddingBottom="@dimen/space_md">

            <!-- Contact card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/card_spacing">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact"
                        style="@style/TextLabelLarge"
                        android:layout_marginBottom="@dimen/space_sm" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:id="@+id/tvPhone"
                            android:text="—"
                            style="@style/TextBodyLarge" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="—"
                        style="@style/TextBodyMedium" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Location card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/card_spacing">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_location"
                        style="@style/TextLabelLarge"
                        android:layout_marginBottom="@dimen/space_sm" />

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        style="@style/TextBodyLarge" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Fixed bottom Call button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCallDonor"
        style="@style/PrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginEnd="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/space_lg"
        android:text="@string/btn_call_donor" />

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/white" />

    </FrameLayout>

</FrameLayout>
