<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Curved red header ─────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/curved_header_height">

            <!-- Background curve -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_curved_header" />

            <!-- Header content: greeting + avatar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/screen_padding"
                android:paddingEnd="@dimen/screen_padding"
                android:layout_marginTop="48dp">

                <!-- Greeting text -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/welcome_to_lifeflow"
                        style="@style/TextHeaderSubtitle" />

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="Hi there!"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:fontFamily="@font/poppins_bold" />

                </LinearLayout>

                <!-- Avatar circle with initials -->
                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="@dimen/avatar_size"
                    android:layout_height="@dimen/avatar_size"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_red"
                    android:textColor="@color/colorPrimary"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="U"
                    android:contentDescription="@string/cd_avatar" />

            </LinearLayout>

        </FrameLayout>

        <!-- ── Stat cards (overlap the curve with negative margin) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="-32dp"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding">

            <!-- Blood type stat card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/StatCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:id="@+id/tvBloodType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        style="@style/TextBloodType" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="Your Blood Type"
                        style="@style/TextBodySmall"
                        android:gravity="center"
                        android:textAlignment="center" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Donors available stat card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/StatCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/card_spacing">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:id="@+id/tvDonorCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        style="@style/TextStatNumber" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/stat_donors_available"
                        style="@style/TextBodySmall"
                        android:gravity="center"
                        android:textAlignment="center" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ── Main content body ─────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingTop="@dimen/space_lg"
            android:paddingBottom="@dimen/space_xl">

            <!-- "What do you want?" section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/what_do_you_want"
                style="@style/TextHeading2" />

            <!-- Quick-action cards: Donate Blood + Request Blood -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/space_md"
                android:weightSum="2">

                <!-- Donate Blood card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDonateDonors"
                    style="@style/ActionCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_logo"
                            android:contentDescription="@string/cd_blood_drop" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/card_donate_blood"
                            style="@style/TextHeading3"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="Find nearby donors →"
                            style="@style/TextBodySmall"
                            android:textColor="@color/colorPrimary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Request Blood card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRequestBlood"
                    style="@style/ActionCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/card_spacing"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_notifications"
                            android:contentDescription="@string/cd_blood_drop" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/card_request_blood"
                            style="@style/TextHeading3"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="Post a request →"
                            style="@style/TextBodySmall"
                            android:textColor="@color/colorPrimary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Blood Requests section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/space_xl">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/section_blood_requests"
                    style="@style/TextHeading2" />

                <TextView
                    android:id="@+id/tvSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    android:textColor="@color/colorPrimary"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_medium"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="@dimen/space_sm"
                    android:paddingEnd="@dimen/space_xs"
                    android:paddingTop="@dimen/space_xs"
                    android:paddingBottom="@dimen/space_xs" />

            </LinearLayout>

            <!-- Recent requests list (non-scrollable, max 3 items) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <!-- Empty state for requests -->
            <LinearLayout
                android:id="@+id/layoutEmptyRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="@dimen/space_md"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_requests"
                    style="@style/TextBodyMedium"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Stats loading indicator -->
            <ProgressBar
                android:id="@+id/progressStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_md"
                android:indeterminateTint="@color/colorPrimary"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
