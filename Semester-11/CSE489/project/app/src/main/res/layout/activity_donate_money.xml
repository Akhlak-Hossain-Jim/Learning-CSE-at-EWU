<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Curved red header ─────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/curved_header_height"
            android:background="@drawable/bg_curved_header">

            <ImageView
                android:id="@+id/btnBack"
                style="@style/HeaderBackButton"
                android:layout_gravity="top|start"
                android:layout_margin="@dimen/space_md"
                android:src="@drawable/ic_arrow_back" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_donate_money"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/subtitle_donate_money"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </FrameLayout>

        <!-- ── Why donate card ───────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding"
            android:layout_marginEnd="@dimen/screen_padding"
            android:layout_marginTop="@dimen/space_lg"
            android:layout_marginBottom="@dimen/card_spacing"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/elevation_card"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_why_donate"
                    style="@style/TextLabelLarge"
                    android:layout_marginBottom="@dimen/space_sm" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/text_why_donate_body"
                    style="@style/TextBodyMedium"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Section header ────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding"
            android:layout_marginBottom="@dimen/space_sm"
            android:text="@string/label_payment_methods"
            style="@style/TextLabelLarge" />

        <!-- ── bKash ─────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding"
            android:layout_marginEnd="@dimen/screen_padding"
            android:layout_marginBottom="@dimen/card_spacing"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/elevation_card"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="bKash"
                    android:textColor="#D7005E"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold"
                    android:layout_marginBottom="@dimen/space_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_send_money"
                    style="@style/TextBodySmall"
                    android:layout_marginBottom="@dimen/space_sm" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvBkashNumber"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/bkash_number"
                        android:textColor="@color/textPrimary"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:letterSpacing="0.05" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyBkash"
                        style="@style/SecondaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_copy"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Nagad ──────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding"
            android:layout_marginEnd="@dimen/screen_padding"
            android:layout_marginBottom="@dimen/card_spacing"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/elevation_card"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nagad"
                    android:textColor="#F7931E"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold"
                    android:layout_marginBottom="@dimen/space_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_send_money"
                    style="@style/TextBodySmall"
                    android:layout_marginBottom="@dimen/space_sm" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvNagadNumber"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/nagad_number"
                        android:textColor="@color/textPrimary"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:letterSpacing="0.05" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyNagad"
                        style="@style/SecondaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_copy"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Rocket ─────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding"
            android:layout_marginEnd="@dimen/screen_padding"
            android:layout_marginBottom="@dimen/card_spacing"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/elevation_card"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rocket"
                    android:textColor="#8B1A8C"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold"
                    android:layout_marginBottom="@dimen/space_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_send_money"
                    style="@style/TextBodySmall"
                    android:layout_marginBottom="@dimen/space_sm" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvRocketNumber"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/rocket_number"
                        android:textColor="@color/textPrimary"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:letterSpacing="0.05" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyRocket"
                        style="@style/SecondaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_copy"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Bank Transfer ─────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding"
            android:layout_marginEnd="@dimen/screen_padding"
            android:layout_marginBottom="@dimen/space_xl"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/elevation_card"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_bank_transfer"
                    android:textColor="@color/colorPrimary"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold"
                    android:layout_marginBottom="@dimen/space_sm" />

                <!-- Bank name row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/space_xs">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_bank_name"
                        style="@style/TextBodySmall" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/bank_name"
                        style="@style/TextBodyMedium"
                        android:textColor="@color/textPrimary" />

                </LinearLayout>

                <!-- Account name row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/space_xs">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_account_name"
                        style="@style/TextBodySmall" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/bank_account_name"
                        style="@style/TextBodyMedium"
                        android:textColor="@color/textPrimary" />

                </LinearLayout>

                <!-- Account number row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/space_xs">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_account_number"
                        style="@style/TextBodySmall" />

                    <TextView
                        android:id="@+id/tvBankAccount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/bank_account_number"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_medium" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyBank"
                        style="@style/SecondaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_copy"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Routing row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_routing"
                        style="@style/TextBodySmall" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/bank_routing"
                        style="@style/TextBodyMedium"
                        android:textColor="@color/textPrimary" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
