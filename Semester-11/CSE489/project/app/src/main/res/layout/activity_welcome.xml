<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <!-- ── Top illustration area (60% of screen) ─────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="6"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="@dimen/space_xl">

        <!-- Logo -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_logo"
            android:contentDescription="@string/cd_app_logo" />

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/app_name"
            android:textColor="@color/colorPrimary"
            android:textSize="28sp"
            android:fontFamily="@font/poppins_bold" />

        <!-- Illustration placeholder — blood bag image area -->
        <ImageView
            android:id="@+id/imgIllustration"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="@dimen/space_lg"
            android:src="@drawable/ic_logo"
            android:scaleType="fitCenter"
            android:contentDescription="@string/cd_blood_drop" />

    </LinearLayout>

    <!-- ── Bottom text + buttons area (40% of screen) ────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingTop="@dimen/space_lg"
        android:paddingBottom="@dimen/space_xl"
        android:gravity="center_horizontal">

        <!-- Tagline heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_tagline"
            style="@style/TextHeading1"
            android:gravity="center"
            android:textAlignment="center" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="Connect with blood donors near you.\nEvery drop counts."
            style="@style/TextBodyMedium"
            android:gravity="center"
            android:textAlignment="center" />

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Login button (primary filled) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            style="@style/PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/btn_login" />

        <!-- Sign Up button (outlined secondary) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignup"
            style="@style/SecondaryButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/btn_signup" />

    </LinearLayout>

</LinearLayout>
